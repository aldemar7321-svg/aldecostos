/**
 * @fileOverview Firestore Security Rules for ProdCost Pro.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model where each user has exclusive access to their own data.
 *
 * Data Structure:
 * All data is nested under /users/{userId}, ensuring data isolation and simplifying authorization.
 * - /users/{userId}: User profile data.
 * - /users/{userId}/priceLists/{priceListId}: Price lists for raw materials.
 * - /users/{userId}/rawMaterials/{rawMaterialId}: Raw material data.
 * - /users/{userId}/laborCosts/{laborCostId}: Labor cost data.
 * - /users/{userId}/productionProcesses/{productionProcessId}: Production process data.
 * - /users/{userId}/overheadCosts/{overheadCostId}: Overhead cost data.
 * - /users/{userId}/consolidatedResults/{consolidatedResultId}: Consolidated results data.
 *
 * Key Security Decisions:
 * - Users can only access their own data.
 * - List operations are allowed only for the owner of the data.
 * - Data validation is relaxed in this prototyping phase to allow rapid iteration.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own user profile data.
     * @path /users/{userId}
     * @allow (create) User with ID matching auth.uid can create their profile.
     * @allow (get, update, delete) Authenticated user can read, update, and delete their own profile.
     * @deny (create, get, update, delete) Users cannot access other user's profiles.
     * @principle Enforces document ownership.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows users to manage their own price lists.
     * @path /users/{userId}/priceLists/{priceListId}
     * @allow (create) Authenticated user can create price lists under their profile.
     * @allow (get, list, update, delete) Authenticated user can read, list, update, and delete their own price lists.
     * @deny (create, get, list, update, delete) Users cannot access other user's price lists.
     * @principle Enforces document ownership for price lists.
     */
    match /users/{userId}/priceLists/{priceListId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows users to manage their own raw materials data.
     * @path /users/{userId}/rawMaterials/{rawMaterialId}
     * @allow (create) Authenticated user can create raw materials under their profile.
     * @allow (get, list, update, delete) Authenticated user can read, list, update, and delete their own raw materials.
     * @deny (create, get, list, update, delete) Users cannot access other user's raw materials.
     * @principle Enforces document ownership for raw materials.
     */
    match /users/{userId}/rawMaterials/{rawMaterialId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows users to manage their own labor costs data.
     * @path /users/{userId}/laborCosts/{laborCostId}
     * @allow (create) Authenticated user can create labor costs under their profile.
     * @allow (get, list, update, delete) Authenticated user can read, list, update, and delete their own labor costs.
     * @deny (create, get, list, update, delete) Users cannot access other user's labor costs.
     * @principle Enforces document ownership for labor costs.
     */
    match /users/{userId}/laborCosts/{laborCostId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows users to manage their own production processes data.
     * @path /users/{userId}/productionProcesses/{productionProcessId}
     * @allow (create) Authenticated user can create production processes under their profile.
     * @allow (get, list, update, delete) Authenticated user can read, list, update, and delete their own production processes.
     * @deny (create, get, list, update, delete) Users cannot access other user's production processes.
     * @principle Enforces document ownership for production processes.
     */
    match /users/{userId}/productionProcesses/{productionProcessId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows users to manage their own overhead costs data.
     * @path /users/{userId}/overheadCosts/{overheadCostId}
     * @allow (create) Authenticated user can create overhead costs under their profile.
     * @allow (get, list, update, delete) Authenticated user can read, list, update, and delete their own overhead costs.
     * @deny (create, get, list, update, delete) Users cannot access other user's overhead costs.
     * @principle Enforces document ownership for overhead costs.
     */
    match /users/{userId}/overheadCosts/{overheadCostId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows users to manage their own consolidated results data.
     * @path /users/{userId}/consolidatedResults/{consolidatedResultId}
     * @allow (create) Authenticated user can create consolidated results under their profile.
     * @allow (get, list, update, delete) Authenticated user can read, list, update, and delete their own consolidated results.
     * @deny (create, get, list, update, delete) Users cannot access other user's consolidated results.
     * @principle Enforces document ownership for consolidated results.
     */
    match /users/{userId}/consolidatedResults/{consolidatedResultId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
  }
}