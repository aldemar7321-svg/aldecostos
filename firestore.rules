
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isCreatingOwnData() {
      return request.auth.uid == request.resource.data.userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isCreatingOwnData() || isOwner(userId);

      match /recipes/{recipeId} {
        allow read, write: if isOwner(userId);
      }

      match /laborCosts/{laborCostId} {
        allow read, write: if isOwner(userId);
      }
      
      match /inventory/{inventoryId} {
        allow read, write: if isOwner(userId);
      }
      
      match /packaging/{packagingId} {
        allow read, write: if isOwner(userId);
      }
      
      match /overhead/{overheadId} {
        allow read, write: if isOwner(userId);
      }

      match /transportCosts/{transportCostId} {
        allow read, write: if isOwner(userId);
      }
      
      match /capitalCosts/{capitalCostId} {
        allow read, write: if isOwner(userId);
      }
      
      match /finishedProducts/{finishedProductId} {
        allow read, write: if isOwner(userId);
      }
      
      match /products/{productId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
