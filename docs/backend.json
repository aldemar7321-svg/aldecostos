{
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/User"
      },
      "description": "Stores public user profile information."
    },
    "/users/{userId}/recipes/{recipeId}": {
      "schema": {
        "$ref": "#/backend/entities/Recipe"
      },
      "description": "Stores user's recipes."
    },
    "/users/{userId}/laborCosts/{laborCostId}": {
      "schema": {
        "$ref": "#/backend/entities/LaborCost"
      },
      "description": "Stores user's labor costs."
    },
    "/users/{userId}/inventory/{inventoryId}": {
      "schema": {
        "$ref": "#/backend/entities/InventoryItem"
      },
      "description": "Stores user's inventory items."
    },
    "/users/{userId}/packaging/{packagingId}": {
      "schema": {
        "$ref": "#/backend/entities/PackagingItem"
      },
      "description": "Stores user's packaging items."
    },
    "/users/{userId}/overhead/{overheadId}": {
      "schema": {
        "$ref": "#/backend/entities/OverheadItem"
      },
      "description": "Stores user's overhead items."
    },
    "/users/{userId}/transportCosts/{transportCostId}": {
      "schema": {
        "$ref": "#/backend/entities/TransportCostItem"
      },
      "description": "Stores user's transport cost items."
    },
    "/users/{userId}/capitalCosts/{capitalCostId}": {
      "schema": {
        "$ref": "#/backend/entities/CapitalCostItem"
      },
      "description": "Stores user's capital cost items."
    },
    "/users/{userId}/finishedProducts/{finishedProductId}": {
      "schema": {
        "$ref": "#/backend/entities/FinishedProduct"
      },
      "description": "Stores user's finished products."
    },
    "/users/{userId}/products/{productId}": {
      "schema": {
        "$ref": "#/backend/entities/Product"
      },
      "description": "Stores user's products."
    }
  },
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "isAnonymous": {
          "type": "boolean"
        }
      }
    },
    "Recipe": {
      "title": "Recipe",
      "description": "A recipe for a product.",
      "type": "object",
      "properties": {}
    },
    "LaborCost": {
      "title": "LaborCost",
      "description": "A labor cost item.",
      "type": "object",
      "properties": {}
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "An inventory item.",
      "type": "object",
      "properties": {}
    },
    "PackagingItem": {
      "title": "PackagingItem",
      "description": "A packaging item.",
      "type": "object",
      "properties": {}
    },
    "OverheadItem": {
      "title": "OverheadItem",
      "description": "An overhead item.",
      "type": "object",
      "properties": {}
    },
    "TransportCostItem": {
      "title": "TransportCostItem",
      "description": "A transport cost item.",
      "type": "object",
      "properties": {}
    },
    "CapitalCostItem": {
      "title": "CapitalCostItem",
      "description": "A capital cost item.",
      "type": "object",
      "properties": {}
    },
    "FinishedProduct": {
      "title": "FinishedProduct",
      "description": "A finished product.",
      "type": "object",
      "properties": {}
    },
    "Product": {
      "title": "Product",
      "description": "A product.",
      "type": "object",
      "properties": {}
    }
  }
}
